# Required: bearer token clients must present in the Authorization header.
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
GRAPPA_MCP_TOKEN=replace-me

# Optional: default working directory for run_command and list_directory.
# Falls back to $HOME if unset.
# GRAPPA_MCP_DEFAULT_CWD=/home/youruser

# Optional: default container name for docker_logs.
# If unset, callers must pass `container` explicitly.
# GRAPPA_MCP_DEFAULT_DOCKER_CONTAINER=my-app

# Bind address and port for the systemd unit template.
# Recommended: bind to a private VPN interface, not 0.0.0.0.
MCP_BIND_HOST=127.0.0.1
MCP_BIND_PORT=8020
